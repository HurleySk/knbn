<UserControl x:Class="Knbn.Extension.UI.KanbanToolWindowControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:converters="clr-namespace:Knbn.Extension.UI.Converters"
             Background="#FF1E1E1E">

    <UserControl.Resources>
        <converters:TimeAgoConverter x:Key="TimeAgoConverter" />
        <BooleanToVisibilityConverter x:Key="BoolToVis"/>

        <DataTemplate x:Key="CardTemplate">
            <Border Background="#FF2D2D30" CornerRadius="4" Padding="10" Margin="0,0,0,6"
                    BorderThickness="3,0,0,0" BorderBrush="{Binding BorderColor}"
                    Opacity="{Binding CardOpacity}">
                <StackPanel>
                    <TextBlock Text="{Binding Title}" Foreground="#FFDDDDDD"
                               FontWeight="Bold" FontSize="13" Margin="0,0,0,3"/>
                    <TextBlock Text="{Binding ProjectName}" Foreground="#FF888888"
                               FontSize="11" Margin="0,0,0,6"/>
                    <Border Background="#FF3A3D41" CornerRadius="2" Padding="4,2"
                            HorizontalAlignment="Left" Margin="0,0,0,6">
                        <TextBlock Foreground="#FF9CDCFE" FontSize="10">
                            <Run Text="{Binding SessionCount, Mode=OneWay}"/>
                            <Run Text=" sessions"/>
                        </TextBlock>
                    </Border>
                    <TextBlock Text="{Binding LatestNote}" Foreground="#FF666666"
                               FontSize="10" TextTrimming="CharacterEllipsis"
                               Visibility="{Binding HasNote, Converter={StaticResource BoolToVis}}"/>
                    <TextBlock Foreground="#FF555555" FontSize="10" Margin="0,3,0,0"
                               Text="{Binding UpdatedAt, Converter={StaticResource TimeAgoConverter}}"/>
                </StackPanel>
            </Border>
        </DataTemplate>

        <Style x:Key="ColumnStyle" TargetType="Border">
            <Setter Property="Background" Value="#FF252526"/>
            <Setter Property="CornerRadius" Value="6"/>
            <Setter Property="Padding" Value="10"/>
        </Style>
    </UserControl.Resources>

    <DockPanel>
        <Border DockPanel.Dock="Top" Background="#FF2D2D30" Padding="10,6" Margin="0,0,0,8">
            <DockPanel>
                <TextBlock Text="knbn" Foreground="#FFDDDDDD" FontWeight="Bold"
                           FontSize="14" VerticalAlignment="Center"/>
                <TextBlock DockPanel.Dock="Right" Foreground="#FF888888" FontSize="11"
                           VerticalAlignment="Center">
                    <Run Text="{Binding TotalActiveCount, Mode=OneWay}"/>
                    <Run Text=" active cards"/>
                </TextBlock>
            </DockPanel>
        </Border>

        <Grid Margin="4">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="8"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="8"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <Border Grid.Column="0" Style="{StaticResource ColumnStyle}">
                <DockPanel>
                    <StackPanel DockPanel.Dock="Top" Orientation="Horizontal" Margin="0,0,0,10">
                        <Ellipse Width="8" Height="8" Fill="#FF4EC9B0" Margin="0,0,6,0"/>
                        <TextBlock Text="ACTIVE" Foreground="#FFAAAAAA" FontSize="11"
                                   FontWeight="Bold" VerticalAlignment="Center"/>
                        <TextBlock Text="{Binding ActiveCards.Count, Mode=OneWay}"
                                   Foreground="#FF666666" FontSize="11" Margin="8,0,0,0"
                                   VerticalAlignment="Center"/>
                    </StackPanel>
                    <ItemsControl ItemsSource="{Binding ActiveCards}"
                                  ItemTemplate="{StaticResource CardTemplate}"/>
                </DockPanel>
            </Border>

            <Border Grid.Column="2" Style="{StaticResource ColumnStyle}">
                <DockPanel>
                    <StackPanel DockPanel.Dock="Top" Orientation="Horizontal" Margin="0,0,0,10">
                        <Ellipse Width="8" Height="8" Fill="#FFDCDCAA" Margin="0,0,6,0"/>
                        <TextBlock Text="WAITING" Foreground="#FFAAAAAA" FontSize="11"
                                   FontWeight="Bold" VerticalAlignment="Center"/>
                        <TextBlock Text="{Binding WaitingCards.Count, Mode=OneWay}"
                                   Foreground="#FF666666" FontSize="11" Margin="8,0,0,0"
                                   VerticalAlignment="Center"/>
                    </StackPanel>
                    <ItemsControl ItemsSource="{Binding WaitingCards}"
                                  ItemTemplate="{StaticResource CardTemplate}"/>
                </DockPanel>
            </Border>

            <Border Grid.Column="4" Style="{StaticResource ColumnStyle}">
                <DockPanel>
                    <StackPanel DockPanel.Dock="Top" Orientation="Horizontal" Margin="0,0,0,10">
                        <Ellipse Width="8" Height="8" Fill="#FF608B4E" Margin="0,0,6,0"/>
                        <TextBlock Text="DONE" Foreground="#FFAAAAAA" FontSize="11"
                                   FontWeight="Bold" VerticalAlignment="Center"/>
                        <TextBlock Text="{Binding DoneCards.Count, Mode=OneWay}"
                                   Foreground="#FF666666" FontSize="11" Margin="8,0,0,0"
                                   VerticalAlignment="Center"/>
                    </StackPanel>
                    <ItemsControl ItemsSource="{Binding DoneCards}"
                                  ItemTemplate="{StaticResource CardTemplate}"/>
                </DockPanel>
            </Border>
        </Grid>
    </DockPanel>
</UserControl>
